{
  "name": "modalogue-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Modalogue monorepo - Headless modal engine",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "dev:website": "turbo run dev --filter=modalogue-website...",
    "format": "prettier --write .",
    "test": "playwright test",
    "test:unit": "turbo run test:unit:run",
    "test:integration": "vitest run",
    "test:integration:watch": "vitest"
  },
  "keywords": [
    "modal",
    "dialog",
    "multi-step",
    "headless",
    "state-management"
  ],
  "author": "Edoardo Guido <ciao@edoardoguido.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edoardoguido/modalogue"
  },
  "homepage": "https://modalogue.dev",
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^18.11.13",
    "@types/react": "^18.0.26",
    "eslint": "^9.27.0",
    "eslint-config-next": "latest",
    "jsdom": "^26.1.0",
    "prettier": "^2.8.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "turbo": "2.9.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@8.12.1"
}
