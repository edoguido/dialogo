{
  "name": "@dialogo/core",
  "version": "0.1.0",
  "description": "Headless state management for multi-step dialogs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage"
  },
  "keywords": [
    "modal",
    "dialog",
    "multi-step",
    "headless",
    "state-management"
  ],
  "author": "Edoardo Guido <ciao@edoardoguido.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edoardoguido/dialogo",
    "directory": "packages/core"
  },
  "homepage": "https://dialogo.dev",
  "peerDependencies": {},
  "dependencies": {},
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "bunchee": "^6.5.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
